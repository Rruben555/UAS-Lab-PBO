<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<ScrollPane fitToWidth="true" style="-fx-fit-to-height: true;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tourism.controller.DestinationDetailFXMLController">
    <VBox spacing="0" style="-fx-fill-height: true;">

        <!-- NAVBAR -->
        <HBox alignment="CENTER_LEFT" prefHeight="72" style="-fx-background-color: rgba(255, 255, 255, 0.95); -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="40" right="40"/>
            </padding>
            <spacing>15</spacing>

            <Label text="CTRS" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="backButton" text="← Back" onAction="#onBackClick"
                    style="-fx-padding: 12 22; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-weight: 600;"/>
        </HBox>

        <!-- DESTINATION HEADER -->
        <VBox spacing="30" style="-fx-padding: 60 40 60 40;">

            <!-- Destination Cover Image -->
            <HBox fx:id="imageContainer" spacing="10" style="-fx-padding: 0 0 10 0;">
                <VBox fx:id="imagePlaceholder" prefHeight="400" prefWidth="800"
                      style="-fx-background-color: linear-gradient(135deg, #89f7fe, #66a6ff); -fx-background-radius: 24;"/>
            </HBox>
            <!-- Destination Info -->
            <GridPane hgap="40">
                <columnConstraints>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
                    <javafx.scene.layout.ColumnConstraints minWidth="300"/>
                </columnConstraints>

                <!-- Left Side: Info -->
                <VBox spacing="20">
                    <VBox spacing="10">
                        <Label fx:id="destinationTitle" text="Loading..." style="-fx-font-size: 42; -fx-font-weight: bold;"/>
                        <Label fx:id="destinationRating" text="" style="-fx-font-size: 16; -fx-text-fill: #f59e0b;"/>
                        <Label fx:id="destinationLocation" text="" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="About This Destination" style="-fx-font-size: 18; -fx-font-weight: 600;"/>
                        <Label fx:id="destinationDescription" text="" style="-fx-text-fill: #374151; -fx-font-size: 14; -fx-wrap-text: true;" wrapText="true"/>
                    </VBox>

                    <GridPane hgap="40">
                        <columnConstraints>
                            <javafx.scene.layout.ColumnConstraints minWidth="150"/>
                            <javafx.scene.layout.ColumnConstraints minWidth="150"/>
                        </columnConstraints>

                        <VBox spacing="8">
                            <Label text="Category" style="-fx-font-weight: 600; -fx-font-size: 14;"/>
                            <Label fx:id="categoryLabel" text="" style="-fx-text-fill: #64748b;"/>
                        </VBox>

                    </GridPane>
                </VBox>

                <!-- Right Side: Action Card -->
                <VBox spacing="16" style="-fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 24; -fx-background-color: white;" GridPane.columnIndex="1">
                    <Label text="Interested?" style="-fx-font-size: 18; -fx-font-weight: 600;"/>
                    <Label text="Share your experience at this amazing destination." style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-wrap-text: true;" wrapText="true"/>
                    <Button fx:id="writeReviewButton" text="Write a Review" onAction="#onWriteReviewClick"
                            style="-fx-padding: 12 32; -fx-background-color: #00d4a4; -fx-text-fill: #111; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-weight: 600; -fx-font-size: 14;" prefWidth="240"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- REVIEWS SECTION -->
        <VBox spacing="20" style="-fx-padding: 60 40 60 40;">

            <VBox spacing="10">
                <Label text="Traveler Reviews" style="-fx-font-size: 24; -fx-font-weight: 600;"/>
                <Label text="Reviews from our community" style="-fx-text-fill: #64748b;"/>
            </VBox>

            <!-- Dynamic Reviews List (populated from API) -->
            <VBox fx:id="reviewsContainer" spacing="16">
                <Label text="Loading reviews..." style="-fx-text-fill: #64748b; -fx-font-size: 14;"/>
            </VBox>

            <Button text="Load More Reviews" onAction="#onLoadMoreClick"
                    style="-fx-padding: 12 32; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 999; -fx-background-radius: 999; -fx-text-fill: #111827; -fx-background-color: white; -fx-font-weight: 600; -fx-font-size: 14;"/>
        </VBox>

        <!-- FOOTER -->
        <VBox spacing="20" alignment="CENTER" style="-fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0; -fx-padding: 40 40 40 40;">
            <Label text="© 2026 CTRS. All rights reserved." style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>
        </VBox>
    </VBox>
</ScrollPane>
