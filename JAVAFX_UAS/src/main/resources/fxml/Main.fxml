<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Separator?>

<ScrollPane fitToWidth="true" style="-fx-fit-to-height: true;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tourism.controller.HomeController">
    <VBox spacing="0" style="-fx-fill-height: true;">

        <!-- NAVBAR -->
        <HBox alignment="CENTER_LEFT" prefHeight="72" style="-fx-background-color: rgba(255, 255, 255, 0.95); -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="40" right="40"/>
            </padding>
            <spacing>15</spacing>

            <!-- Logo -->
            <Label text="CTRS" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Action Buttons -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="userLabel" text="" style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>
                <Button fx:id="adminDashboardBtn" text="Admin Dashboard" onAction="#onAdminDashboardClick"
                        visible="false" managed="false"
                        style="-fx-padding: 10 20; -fx-background-color: #111827; -fx-text-fill: white; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-weight: 600; -fx-font-size: 13;"/>
                <Button text="Logout" onAction="#onLogoutClick"
                        style="-fx-padding: 10 20; -fx-background-color: #ef4444; -fx-text-fill: white; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-weight: 600; -fx-font-size: 13;"/>
            </HBox>
        </HBox>

        <!-- HERO SECTION -->
        <VBox alignment="CENTER" prefHeight="500" spacing="20" style="-fx-background-color: linear-gradient(to bottom, #cfefff, #fff8ea); -fx-padding: 100 0 80 0;">
            <padding>
                <Insets left="40" right="40"/>
            </padding>

            <!-- Hero Tag -->
            <HBox alignment="CENTER">
                <Label text="Your Review Means Everything" style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-padding: 8 18; -fx-border-radius: 999; -fx-background-radius: 999; -fx-font-size: 13; -fx-font-weight: 600;"/>
            </HBox>

            <!-- Hero Title -->
            <Label text="Discover Places&#10;Worth Traveling For" style="-fx-font-size: 56; -fx-font-weight: bold; -fx-text-fill: #111827; -fx-text-alignment: center;" wrapText="true"/>

            <!-- Hero Subtitle -->
            <Label text="Read authentic travel reviews, discover hidden gems,&#10;and plan unforgettable adventures with insights from&#10;real travelers around the globe." style="-fx-font-size: 16; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>



            <!-- Search Panel -->
            <VBox style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 18; -fx-padding: 22; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 25, 0, 0, 10); -fx-max-width: 900;">
                <GridPane hgap="12" vgap="12">
                    <columnConstraints>
                        <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" minWidth="200" prefWidth="400"/>
                        <javafx.scene.layout.ColumnConstraints minWidth="130" prefWidth="130"/>
                        <javafx.scene.layout.ColumnConstraints minWidth="130" prefWidth="130"/>
                        <javafx.scene.layout.ColumnConstraints minWidth="90" prefWidth="90"/>
                    </columnConstraints>

                    <TextField fx:id="searchTextField" promptText="Search destinations..." style="-fx-padding: 14; -fx-font-size: 14; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 10; -fx-control-inner-background: white;"/>
                    <ComboBox fx:id="categoryCombo" promptText="Category" style="-fx-padding: 0 12; -fx-font-size: 14; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 10;" GridPane.columnIndex="1" prefWidth="130"/>
                    <ComboBox fx:id="ratingCombo" promptText="Rating" style="-fx-padding: 0 12; -fx-font-size: 14; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 10;" GridPane.columnIndex="2" prefWidth="130"/>
                    <Button fx:id="searchButton" text="Search" onAction="#onSearchClick" style="-fx-padding: 12 20; -fx-background-color: #111; -fx-text-fill: white; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-weight: 600; -fx-font-size: 14;" GridPane.columnIndex="3"/>
                </GridPane>
            </VBox>
        </VBox>

        <!-- TRENDING DESTINATIONS SECTION -->
        <VBox spacing="40" style="-fx-padding: 80 40 80 40;">

            <!-- Section Header -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="FEATURED PLACES" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #00b38b; -fx-letter-spacing: 1;"/>
                <Label text="Trending Destinations" style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label text="Explore the world's most loved destinations reviewed by thousands of travelers." style="-fx-font-size: 15; -fx-text-fill: #64748b; -fx-text-alignment: center;" wrapText="true"/>
            </VBox>

            <!-- Dynamic Destination Cards Grid (populated from API) -->
            <GridPane fx:id="destinationGrid" hgap="24" vgap="24">
                <columnConstraints>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
                </columnConstraints>
            </GridPane>
        </VBox>

        <!-- CATEGORIES SECTION -->
        <VBox spacing="40" style="-fx-background-color: #fafafa; -fx-padding: 80 40 80 40;">
            <VBox alignment="CENTER" spacing="10">
                <Label text="EXPLORE" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #00b38b; -fx-letter-spacing: 1;"/>
                <Label text="Browse Categories" style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            </VBox>

            <GridPane hgap="20" vgap="20">
                <columnConstraints>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
                    <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <VBox alignment="CENTER" spacing="12" style="-fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28; -fx-background-color: white;">
                    <Label text="🏖️" style="-fx-font-size: 32;"/>
                    <Label text="Beaches" style="-fx-font-size: 14; -fx-font-weight: 600;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="12" style="-fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28; -fx-background-color: white;" GridPane.columnIndex="1">
                    <Label text="⛰️" style="-fx-font-size: 32;"/>
                    <Label text="Mountains" style="-fx-font-size: 14; -fx-font-weight: 600;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="12" style="-fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28; -fx-background-color: white;" GridPane.columnIndex="2">
                    <Label text="🌳" style="-fx-font-size: 32;"/>
                    <Label text="Nature" style="-fx-font-size: 14; -fx-font-weight: 600;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="12" style="-fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28; -fx-background-color: white;" GridPane.columnIndex="3">
                    <Label text="🏛️" style="-fx-font-size: 32;"/>
                    <Label text="Heritage" style="-fx-font-size: 14; -fx-font-weight: 600;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="12" style="-fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28; -fx-background-color: white;" GridPane.columnIndex="4">
                    <Label text="🍜" style="-fx-font-size: 32;"/>
                    <Label text="Culinary" style="-fx-font-size: 14; -fx-font-weight: 600;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="12" style="-fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 28; -fx-background-color: white;" GridPane.columnIndex="5">
                    <Label text="📷" style="-fx-font-size: 32;"/>
                    <Label text="Photography" style="-fx-font-size: 14; -fx-font-weight: 600;"/>
                </VBox>
            </GridPane>
        </VBox>



        <!-- CTA SECTION -->
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #0f172a; -fx-padding: 80 40 80 40;">
            <Label text="Ready To Share Your Journey?" style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Help fellow travelers discover amazing places by sharing your experiences and recommendations." style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8); -fx-text-alignment: center;" wrapText="true"/>
        </VBox>

        <!-- FOOTER -->
        <VBox spacing="20" alignment="CENTER" style="-fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0; -fx-padding: 40 40 40 40;">
            <Label text="© 2026 CTRS. All rights reserved." style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-text-alignment: center;"/>
        </VBox>
    </VBox>
</ScrollPane>