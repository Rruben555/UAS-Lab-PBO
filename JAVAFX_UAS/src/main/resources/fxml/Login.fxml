<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tourism.controller.LoginController"
      style="-fx-background-color: #f8fafc;">

    <!-- Left Side: Branding -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="30"
          style="-fx-background-color: linear-gradient(to bottom right, #cfefff, #fff8ea); -fx-padding: 60;">
        <Label text="CTRS" style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        <Label text="Discover Amazing&#10;Destinations"
               style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #111827; -fx-text-alignment: center;"
               wrapText="true"/>
        <Label text="Read authentic travel reviews, discover hidden gems,&#10;and plan unforgettable adventures with insights from&#10;real travelers around the globe."
               style="-fx-font-size: 14; -fx-text-fill: #64748b; -fx-text-alignment: center;"
               wrapText="true"/>
    </VBox>

    <!-- Right Side: Login Form -->
    <VBox alignment="CENTER" prefWidth="420" style="-fx-background-color: white; -fx-padding: 60 50 60 50;" spacing="16">

        <Label text="Sign In" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        <Label text="Selamat datang kembali!" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>

        <VBox spacing="6" maxWidth="320">
            <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <TextField fx:id="usernameField" promptText="Masukkan username"
                       style="-fx-padding: 12; -fx-font-size: 14; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;"/>
        </VBox>

        <VBox spacing="6" maxWidth="320">
            <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <PasswordField fx:id="passwordField" promptText="Masukkan password"
                           style="-fx-padding: 12; -fx-font-size: 14; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;"/>
        </VBox>

        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #ef4444; -fx-font-size: 12;" maxWidth="320"/>

        <Button fx:id="signInBtn" text="Sign In" onAction="#onSignInClick"
                maxWidth="320" prefWidth="320"
                style="-fx-padding: 13 20; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-color: #111827; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Belum punya akun?" style="-fx-text-fill: #64748b;"/>
            <Hyperlink text="Daftar di sini" onAction="#onRegisterLinkClick"
                       style="-fx-text-fill: #00d4a4; -fx-font-weight: bold; -fx-border-width: 0;"/>
        </HBox>

    </VBox>
</HBox>
